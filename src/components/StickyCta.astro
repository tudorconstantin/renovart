---
// StickyCta — the conversion centerpiece (D-04..D-06).
// Fixed full-width bottom bar with two equal buttons: Sună (tel:) + WhatsApp
// (wa.me), both sourced from business.ts. Present on every viewport; on desktop
// it groups/centers into a compact floating action group.
import { business } from '../data/business';
---

<div class="cta" role="region" aria-label="Contact rapid">
  <div class="cta__inner">
    <a
      class="cta__btn cta__btn--call"
      href={business.telHref}
      aria-label={`Sună la ${business.phoneDisplay}`}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M6.6 10.8a15.9 15.9 0 006.6 6.6l2.2-2.2a1 1 0 011-.24 11.3 11.3 0 003.6.58 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.3 11.3 0 00.58 3.6 1 1 0 01-.24 1L6.6 10.8z"
          fill="currentColor"
        />
      </svg>
      <span>Sună</span>
    </a>
    <a
      class="cta__btn cta__btn--wa"
      href={business.whatsappHref}
      aria-label="Trimite mesaj WhatsApp"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 2a10 10 0 00-8.6 15l-1.4 5 5.1-1.3A10 10 0 1012 2zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-3.9-4.7-4.1-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.5c-.2.2-.3.3-.1.6.1.3.7 1.1 1.4 1.8 1 .8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.9.9c.3.1.4.2.5.3.1.2.1.7-.1 1.3z"
          fill="currentColor"
        />
      </svg>
      <span>WhatsApp</span>
    </a>
  </div>
</div>

<style>
  .cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 80; /* above content, below open drawer (90/100) */
    background: var(--color-bg);
    border-top: 1px solid var(--color-slate-600);
    box-shadow: var(--shadow-bar);
    padding-bottom: env(safe-area-inset-bottom);
  }

  .cta__inner {
    display: flex;
    gap: 0;
  }

  .cta__btn {
    flex: 1 1 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: 56px;
    color: var(--color-on-dark);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.01em;
    font-size: 1rem;
  }

  .cta__btn--call {
    background: var(--color-accent);
  }
  .cta__btn--call:hover {
    background: var(--color-accent-hover);
  }

  .cta__btn--wa {
    background: var(--color-whatsapp);
  }
  .cta__btn--wa:hover {
    background: var(--color-whatsapp-hover);
  }

  .cta__btn:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
    box-shadow: inset 0 0 0 5px var(--color-accent-300);
  }

  /* Desktop: compact centered floating group, not full-bleed (D-05). */
  @media (min-width: 768px) {
    .cta {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      width: min(480px, calc(100% - var(--space-xl)));
      margin-bottom: var(--space-md);
      border: 1px solid var(--color-slate-600);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .cta__btn:first-child {
      border-right: 1px solid var(--color-slate-600);
    }
  }
</style>
