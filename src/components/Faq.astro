---
// Visible, always-on FAQ (PAG-05) — zero JS, no accordion, no disclosure widget.
// Renders the single-source faqCopy collection items as semantic <h3> question
// + <p> answer pairs so the content is in the static DOM for AEO crawlers and
// screen readers. The same faqCopy array also feeds faqPageSchema() (no drift).
// Copy is CMS-editable JSON (src/data/copy/faq.json); array order is preserved.
import { getCollection } from 'astro:content';
const faq = (await getCollection('faqCopy')).map((e) => e.data);
---

<section class="faq" aria-labelledby="faq-title">
  <h2 id="faq-title">Întrebări frecvente</h2>
  <div class="faq__list">
    {
      faq.map((item) => (
        <div class="faq__item">
          <h3 class="faq__q">{item.question}</h3>
          <p class="faq__a">{item.answer}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .faq {
    margin-top: var(--space-2xl);
  }

  #faq-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-lg);
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .faq__q {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-sm);
  }

  .faq__a {
    color: var(--color-slate-700);
    margin: 0;
    max-width: 70ch;
  }
</style>
