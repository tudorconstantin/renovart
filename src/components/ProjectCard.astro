---
// ProjectCard — a single portfolio grid card (LUC-03, D-02, 02-UI-SPEC §Project Card).
// The WHOLE card is one focusable <a> to the detail page (one tab stop, no nested
// interactive elements, ≥48px hit area). Cover via <Picture> with a reserved 3/2
// aspect box (zero CLS). All tokens inherited from Phase 1 (global.css).
//
// NOTE: `featured` is established by the schema here and the real D-11 project is
// featured: true — but the homepage featured PULL (LUC-06) is OUT OF SCOPE this
// phase; it lands in Phase 3.
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'lucrari'>;
}

const { entry } = Astro.props;
const { title, location, date, coverImage } = entry.data;

const dateLabel = new Intl.DateTimeFormat('ro-RO', {
  year: 'numeric',
  month: 'long',
}).format(date);
---

<a class="card" href={`/lucrari/${entry.id}`}>
  <div class="card__media">
    <Picture
      src={coverImage}
      formats={['avif', 'webp']}
      widths={[400, 800]}
      sizes="(max-width: 768px) 100vw, 33vw"
      loading="lazy"
      alt={`${title} — ${location}`}
    />
  </div>
  <div class="card__body">
    <h2 class="card__title">{title}</h2>
    <p class="card__meta">{location} · {dateLabel}</p>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-slate-600);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    color: inherit;
    text-decoration: none;
    /* Top accent bar reserved (transparent at rest, terracotta on hover) so the
       hover lift never shifts layout. */
    border-top: 2px solid transparent;
  }

  .card__media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-surface);
  }

  .card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card__body {
    padding: var(--space-md);
  }

  .card__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-xs);
  }

  .card__meta {
    margin: 0;
    color: var(--color-slate-500);
    font-size: 1rem;
  }

  @media (min-width: 768px) {
    .card__title {
      font-size: 1.75rem;
    }
  }

  /* Hover affordance — pointer + reduced-motion respected (LUC a11y).
     Lifts to --shadow-md + a 2px terracotta top accent. */
  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        box-shadow var(--motion-fast),
        border-top-color var(--motion-fast);
    }
  }

  @media (hover: hover) {
    .card:hover {
      box-shadow: var(--shadow-md);
      border-top-color: var(--color-accent);
    }
  }

  /* Focus-visible uses the inherited global terracotta ring — never removed. */
</style>
