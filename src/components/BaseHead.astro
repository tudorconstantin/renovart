---
// SEO / meta helper. Renders charset, viewport, title, description, Open Graph,
// and Twitter card tags. Per-page meta + JSON-LD are extended via BaseLayout's
// <slot name="head" />.
import { business } from '../data/business';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = business.defaultDescription,
  image = business.ogImage,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? business.domain);
// Absolute OG/Twitter image URL so social unfurls (WhatsApp/Facebook/LinkedIn/X)
// resolve the preview image (WR-02). `image` defaults to business.ogImage but a
// page may override it.
const ogImage = new URL(image, Astro.site ?? business.domain).href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="canonical" href={canonical.href} />

<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="ro_RO" />
<meta property="og:site_name" content={business.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={`${business.name} — renovarea scărilor de bloc`} />

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
