---
// Non-visual JSON-LD emitter. Renders one <script type="application/ld+json">
// containing the serialized `data` object/graph, injected through BaseLayout's
// <slot name="head" />.
//
// SECURITY: `set:html` injects the string RAW (no Astro escaping). This is safe
// here ONLY because `data` is trusted, build-time, project-owned content
// (business.ts / faq.ts / services.ts) — NEVER user/request input. JSON.stringify
// provides JSON escaping (", \, control chars); ro-RO diacritics (ă â î ș ț) pass
// through as valid UTF-8 string content. The `.replace(/</g, '<')` hardens
// against a literal "</script>" ever appearing in copy (defense-in-depth).
// `is:inline` keeps Astro from bundling/optimizing the block — it is content,
// not executable JS.
interface Props {
  data: Record<string, unknown> | Record<string, unknown>[];
}
const { data } = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify(data).replace(/</g, '\\u003c')} is:inline></script>
