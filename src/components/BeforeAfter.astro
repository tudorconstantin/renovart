---
// BeforeAfter — accessible before/after comparison slider (LUC-05, D-04, D-05).
// 02-UI-SPEC §"Before/after slider" + 02-RESEARCH §"Pattern 4".
//
// Design: no-JS FIRST. The default CSS renders the two images side-by-side, each
// clearly labeled "Înainte" / "După" (D-05 fallback) — fully usable with zero JS.
// A ~10-line scoped <script> adds the `.ba--js` class and switches to a single
// stacked aspect-ratio:4/3 box where the "După" layer is clipped by `--pos`
// (driven by a native <input type="range">). The range gives keyboard operability,
// focus, and ARIA semantics for free (CLAUDE.md: vanilla JS only, NO slider libs).
//
// Key a11y invariants (RESEARCH A3 / Pitfall 4):
//   - enhanced range is opacity:0 (NOT display:none) → stays in tab order.
//   - explicit :focus-visible ring on the transparent range (it IS the affordance).
//   - clip update is instantaneous (never transitioned) → reduced-motion + no lag.
//   - .ba reserves aspect-ratio:4/3 + object-fit:cover → zero CLS.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt?: string;
  afterAlt?: string;
}

const {
  before,
  after,
  beforeAlt = 'Înainte de renovare — casa scării în starea inițială',
  afterAlt = 'După renovare — casa scării finalizată',
} = Astro.props;
---

<figure class="ba" data-ba style="--pos: 50%;">
  {/* BEFORE — bottom layer / left cell in the no-JS fallback */}
  <div class="ba__img ba__before">
    <Picture
      src={before}
      formats={['avif', 'webp']}
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading="lazy"
      alt={beforeAlt}
    />
    <span class="ba__label ba__label--before">Înainte</span>
  </div>

  {/* AFTER — top layer (clipped by --pos when enhanced) / right cell in fallback */}
  <div class="ba__img ba__after">
    <Picture
      src={after}
      formats={['avif', 'webp']}
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading="lazy"
      alt={afterAlt}
    />
    <span class="ba__label ba__label--after">După</span>
  </div>

  {/* The control: a native range. Keyboard + focus + AT ready. Hidden until JS. */}
  <input
    class="ba__range"
    type="range"
    min="0"
    max="100"
    value="50"
    step="1"
    aria-label="Comparați înainte și după — glisați pentru a dezvălui"
  />
  <span class="ba__handle" aria-hidden="true"></span>
</figure>

<style>
  /* ─── No-JS DEFAULT (D-05 fallback): side-by-side labeled pair ──────────── */
  .ba {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    position: relative;
    margin: 0;
  }

  .ba__img {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .ba__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Range + handle are hidden until JS upgrades the component. */
  .ba__range,
  .ba__handle {
    display: none;
  }

  .ba__label {
    position: absolute;
    bottom: var(--space-sm);
    left: var(--space-sm);
    background: var(--color-slate-900);
    color: var(--color-on-dark);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.2;
  }

  /* ─── Enhanced (.ba--js): single stacked box + range-driven clip overlay ── */
  .ba--js {
    display: block; /* stop being a 2-col grid; stack the two layers */
    /* WR-01: reserve 4:3 ONLY in the enhanced stacked box (zero CLS). The no-JS
       side-by-side fallback keeps each image at its natural/landscape ratio so
       1600×1200 demo seeds are not crushed into portrait cells. */
    aspect-ratio: 4 / 3;
  }

  .ba--js .ba__img {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
  }

  /* "După" is the top layer, revealed from the left as --pos grows. The clip is
     NEVER transitioned (reduced-motion + avoids drag lag). */
  .ba--js .ba__after {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }

  /* Full-area transparent hit-layer. opacity:0 — NOT display:none — so the range
     stays focusable and in the tab order (Pitfall 4). */
  .ba--js .ba__range {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    opacity: 0;
    cursor: ew-resize;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
  }

  /* Decorative vertical seam handle at the reveal position. */
  .ba--js .ba__handle {
    display: block;
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 2px;
    background: var(--color-on-dark);
    transform: translateX(-50%);
    pointer-events: none;
    box-shadow: 0 0 0 1px rgba(15, 27, 45, 0.35);
  }

  /* Visible focus ring on the transparent range — this IS the focus affordance
     for keyboard users (Pitfall 4 / A3). Offset inward so it frames the box. */
  .ba--js .ba__range:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: -3px;
  }

  /* Pointer affordance on the handle only when motion is welcome. The clip itself
     is never transitioned. */
  @media (prefers-reduced-motion: no-preference) {
    .ba--js .ba__handle {
      transition: left var(--motion-fast);
    }
  }
</style>

<script>
  // ~10-line enhancer, one listener per slider. No library, no pointermove/touch
  // math: the native range `input` event fires for pointer drag, touch, AND
  // keyboard (arrows / Home / End / PageUp / PageDown).
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((ba) => {
    const range = ba.querySelector('.ba__range');
    if (!(range instanceof HTMLInputElement)) return;
    ba.classList.add('ba--js'); // switch to the overlay layout
    const sync = () => ba.style.setProperty('--pos', range.value + '%');
    range.addEventListener('input', sync);
    sync(); // initialise to value="50"
  });
</script>
