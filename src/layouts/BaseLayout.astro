---
// Base shell for every page (LAY-01): <html lang="ro">, per-page meta slot,
// self-hosted fonts, and the Cloudflare Web Analytics beacon stub.
// Plan 02 will insert Header / StickyCta / Footer around the default <slot/>.
import { Font } from 'astro:assets';
import { business } from '../data/business';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import StickyCta from '../components/StickyCta.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = business.defaultDescription } = Astro.props;

// LAY-01: Cloudflare Web Analytics token, supplied at build time via the
// PUBLIC_CF_BEACON_TOKEN env var (blank locally; real value set in the GitHub
// Actions environment at launch — tracked on the handoff checklist). When blank
// the beacon <script> is NOT emitted, so no spurious requests fire with a
// placeholder token (WR-01).
const CF_BEACON_TOKEN = import.meta.env.PUBLIC_CF_BEACON_TOKEN ?? '';
---

<!doctype html>
<html lang="ro">
  <head>
    <BaseHead title={title} description={description} />

    {/* Self-hosted fonts (D-03): preload the above-the-fold display face only */}
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" />

    <slot name="head" />

    {/* Cloudflare Web Analytics — cookieless beacon. Only emitted when a real
        token is configured via PUBLIC_CF_BEACON_TOKEN (WR-01). */}
    {CF_BEACON_TOKEN && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${CF_BEACON_TOKEN}"}`}
      ></script>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <StickyCta />
    <Footer />
  </body>
</html>

<style>
  /* Occlusion guard (D-06): reserve space below the footer equal to the fixed
     sticky CTA bar height (~56px) + iOS safe-area inset, so the bar never hides
     the footer or bottom tap targets. */
  body {
    padding-bottom: calc(56px + env(safe-area-inset-bottom));
  }

  /* On desktop the CTA floats with a bottom margin, so reserve a bit more. */
  @media (min-width: 768px) {
    body {
      padding-bottom: calc(56px + var(--space-md) + env(safe-area-inset-bottom));
    }
  }
</style>
