---
// /despre — "Despre noi" page (PAG-03, COP-01/02, SEO-01/02).
// Static, ro-RO, AEO-extractable: honest company story, the full "Cum lucrăm"
// numbered process (evaluare/deviz → planificare → execuție → predare/garanție),
// procurement reassurances for asociații de proprietari, and a closing CTA.
// NO JSON-LD here — Despre is not in the per-page structured-data emission list
// (CONTEXT). All contact actions come from the single-source NAP module.
import BaseLayout from '../layouts/BaseLayout.astro';
import { business } from '../data/business';

const title = `Despre — ${business.name}`;
const description =
  'Cum lucrăm la renovarea scărilor de bloc: evaluare și deviz clar, planificare, execuție și predare cu garanție. Lucrăm cu asociații de proprietari din Cluj-Napoca, cu factură și plată pe etape.';
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <div class="intro">
      <h1>Despre {business.name}</h1>
      <p class="lead">
        Suntem o echipă din Cluj-Napoca specializată în renovarea scărilor de
        bloc — zugrăveli, reparații și finisaje pentru casa scării. Lucrăm
        direct cu administratorii și asociațiile de proprietari, cu lucruri
        spuse pe șleau de la început: ce se face, în cât timp și cu ce buget.
        Fără promisiuni umflate — preferăm să fim corecți acum și recomandați
        mai departe.
      </p>
    </div>

    <section class="block" aria-labelledby="cum-lucram">
      <h2 id="cum-lucram">Cum lucrăm</h2>
      <p>
        Lucrarea trece prin patru pași clari, ca să știți tot timpul la ce etapă
        suntem:
      </p>
      <ol class="steps">
        <li class="steps__item">
          <h3 class="steps__title">1. Evaluare și deviz</h3>
          <p>
            Venim la fața locului, măsurăm și vă dăm un deviz clar, în scris, cu
            ce se face și cât costă. Fără costuri ascunse.
          </p>
        </li>
        <li class="steps__item">
          <h3 class="steps__title">2. Planificare</h3>
          <p>
            Stabilim împreună perioada și ordinea lucrărilor, astfel încât
            accesul în scară să fie afectat cât mai puțin pentru locatari.
          </p>
        </li>
        <li class="steps__item">
          <h3 class="steps__title">3. Execuție</h3>
          <p>
            Echipa execută lucrarea curat și ordonat, cu protejarea suprafețelor
            și curățenie la final de zi. Vă ținem la curent cu progresul.
          </p>
        </li>
        <li class="steps__item">
          <h3 class="steps__title">4. Predare și garanție</h3>
          <p>
            Predăm lucrarea finalizată, primiți factură, iar pentru lucrările
            executate oferim garanție. Rămânem disponibili dacă apare ceva.
          </p>
        </li>
      </ol>
    </section>

    <section class="block block--surface" aria-labelledby="de-ce-noi">
      <h2 id="de-ce-noi">De ce noi</h2>
      <p>Lucrăm transparent și pe înțelesul unei asociații de proprietari:</p>
      <ul class="list">
        <li>Deviz clar, în scris, înainte de a începe</li>
        <li>Factură pentru fiecare lucrare</li>
        <li>Lucrăm cu asociații de proprietari și administratori de bloc</li>
        <li>Plată pe etape, pe măsură ce avansează lucrarea</li>
      </ul>
    </section>

    <section class="block" aria-labelledby="contact">
      <h2 id="contact">Hai să vorbim despre scara dumneavoastră</h2>
      <p class="cta-instruction">
        Sunați sau scrieți-ne pe WhatsApp — vă răspundem rapid și venim pentru o
        evaluare.
      </p>

      <div class="cta-cluster">
        <a
          class="cta-btn cta-btn--call"
          href={business.telHref}
          aria-label={`Sună la ${business.phoneDisplay}`}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M6.6 10.8a15.9 15.9 0 006.6 6.6l2.2-2.2a1 1 0 011-.24 11.3 11.3 0 003.6.58 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.3 11.3 0 00.58 3.6 1 1 0 01-.24 1L6.6 10.8z"
              fill="currentColor"
            />
          </svg>
          <span>Sună</span>
        </a>

        <a
          class="cta-btn cta-btn--wa"
          href={business.whatsappHref}
          aria-label="Scrie-ne pe WhatsApp despre renovarea scării"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M12 2a10 10 0 00-8.6 15l-1.4 5 5.1-1.3A10 10 0 1012 2zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-3.9-4.7-4.1-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.5c-.2.2-.3.3-.1.6.1.3.7 1.1 1.4 1.8 1 .8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.9.9c.3.1.4.2.5.3.1.2.1.7-.1 1.3z"
              fill="currentColor"
            />
          </svg>
          <span>WhatsApp</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  .intro {
    margin-bottom: var(--space-xl);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-md);
  }

  .lead {
    font-size: 1rem;
    color: var(--color-slate-700);
    margin: 0;
    max-width: 70ch;
  }

  .block {
    margin-top: var(--space-xl);
  }

  .block--surface {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-md);
  }

  .block > p {
    color: var(--color-slate-700);
    margin: 0 0 var(--space-md);
    max-width: 70ch;
  }

  /* "Cum lucrăm" numbered process — semantic <ol> with an <h3> per step. */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .steps__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-sm);
  }

  .steps__item p {
    color: var(--color-slate-700);
    margin: 0;
    max-width: 70ch;
  }

  .list {
    margin: 0;
    padding-left: var(--space-lg);
    color: var(--color-slate-700);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cta-instruction {
    color: var(--color-slate-700);
    max-width: 70ch;
  }

  .cta-cluster {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: 56px;
    padding: 0 var(--space-md);
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.01em;
  }

  .cta-btn--call {
    background: var(--color-accent);
    color: var(--color-on-dark);
  }
  .cta-btn--call:hover {
    background: var(--color-accent-hover);
  }

  .cta-btn--wa {
    background: var(--color-whatsapp);
    color: var(--color-on-dark);
  }
  .cta-btn--wa:hover {
    background: var(--color-whatsapp-hover);
  }

  /* Inherited global :focus-visible ring applies; never remove it. */

  @media (min-width: 768px) {
    .page {
      padding: var(--space-3xl) var(--space-lg);
    }
    h1 {
      font-size: 2rem;
    }
    h2 {
      font-size: 1.75rem;
    }
    .block {
      margin-top: var(--space-2xl);
    }
    .cta-cluster {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-md);
    }
    .cta-btn {
      flex: 1 1 auto;
    }
  }
</style>
