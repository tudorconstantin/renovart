---
// Project detail page — /lucrari/[slug] (LUC-04, D-03, D-12).
// 02-UI-SPEC §"Project detail" + 02-RESEARCH §"Pattern 3".
//
// Astro 6: render() is a STANDALONE import from 'astro:content' (NOT entry.render()
// — that method is removed for glob-loader collections; RESEARCH Pitfall 1).
// getStaticPaths maps params.slug = entry.id (glob derives id from the dir name).
//
// Conditional media render (D-05): a project with before/after `pairs` shows the
// slider; an after-only project (pairs:[] + populated `gallery`, the real Cluj
// project) shows an accessible mixed-orientation gallery. A broken/empty slider is
// NEVER rendered. Image fields are /src/assets/lucrari/ strings resolved via the
// import.meta.glob bridge (resolveLucrareImage) so astro:assets still optimizes them.
//
// Breadcrumb DOM was shipped in Phase 2; the matching BreadcrumbList JSON-LD
// <script> is now emitted here (Phase 3, SEO-05) — Acasă → Lucrări → {title},
// positions 1-3, the final (current) crumb omits `item` per Google guidance.
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import JsonLd from '../../components/JsonLd.astro';
import { breadcrumbList } from '../../data/schema';
import { resolveLucrareImage } from '../../lib/resolveLucrareImage';

export async function getStaticPaths() {
  const entries = await getCollection('lucrari');
  return entries.map((entry) => ({
    params: { slug: entry.id }, // param name matches the [slug].astro filename
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry); // Astro 6 standalone render() → MDX body
const { title, location, date, pairs, gallery } = entry.data;

// D-05 invariant: render the slider IFF before/after pairs exist; otherwise the
// gallery — never a broken/empty slider. Image fields are /src/assets/lucrari/
// strings (D-02); resolve them through the import.meta.glob bridge into
// ImageMetadata at build so <Picture>/<BeforeAfter> still emit AVIF/WebP + srcset.
const hasPairs = pairs.length > 0;
const hasGallery = gallery.length > 0;
// CR-01: the schema `.refine()` already rejects the empty-both shape at content-load,
// but guard here too (defense in depth, consistent with resolveLucrareImage's
// fail-closed philosophy) so this page can NEVER emit an empty, labelled gallery <ul>.
if (!hasPairs && !hasGallery) {
  throw new Error(
    `Lucrarea "${entry.id}" nu are nici perechi înainte/după, nici galerie — ` +
      `adăugați cel puțin o imagine.`,
  );
}
const resolvedPairs = await Promise.all(
  pairs.map(async (p) => ({
    before: await resolveLucrareImage(p.before),
    after: await resolveLucrareImage(p.after),
  })),
);
// WR-02/WR-03: keep the ORIGINAL frontmatter path beside each resolved image so alt-text
// is keyed off the curated stem (which we control) and not the hashed astro:assets output
// `src` (which can change and silently drop all curated alts → a11y/AEO regression).
const resolvedGallery = await Promise.all(
  gallery.map(async (g) => ({ img: await resolveLucrareImage(g), path: g })),
);

// BreadcrumbList JSON-LD (SEO-05) matching the breadcrumb DOM below. The final
// crumb (current page) has no `url`, so breadcrumbList emits no `item` for it.
const crumbs = [
  { name: 'Acasă', url: '/' },
  { name: 'Lucrări', url: '/lucrari' },
  { name: title },
];
const breadcrumbLd = { '@context': 'https://schema.org', ...breadcrumbList(crumbs) };

const dateLabel = new Intl.DateTimeFormat('ro-RO', {
  year: 'numeric',
  month: 'long',
}).format(date);

// Factual ro-RO alt texts for the real D-11 gallery photos, keyed by the EXACT
// frontmatter filename stem (02-UI-SPEC §Gallery alt-text guidance — describe what the
// photos actually show, no invented specifics). WR-02: keyed by the curated stem we
// control (e.g. `cluj-trepte-bordo`), NOT a loose substring of the hashed output `src`,
// so a future filename or a change to Astro's asset naming can't mis-attribute or
// silently drop alts. Falls back to "{title} — fotografie {n}" for genuine extras.
const GALLERY_ALT: Record<string, string> = {
  'cluj-trepte-bordo': 'Trepte renovate cu finisaj bordo și mână curentă vopsită',
  'cluj-palier-vopsit': 'Palier proaspăt vopsit, pereți și tavan în alb',
  'cluj-lambriu-vertical': 'Panou decorativ vertical din lambriu pe palier',
  'cluj-usi-acces': 'Zona ușilor de acces la apartamente, după renovare',
  'cluj-corp-iluminat': 'Corp de iluminat montat pe tavanul renovat',
};

// WR-02/WR-03: derive the alt from the ORIGINAL frontmatter path stem (exact match on
// the curated key), not the hashed astro:assets output `src`. A genuine "extra" photo
// with no mapped alt still gets a sensible numbered fallback.
const galleryAlt = (path: string, i: number): string => {
  const stem = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
  return GALLERY_ALT[stem] ?? `${title} — fotografie ${i + 1}`;
};
---

<BaseLayout title={`${title} — Renovart Interiors`}>
  <JsonLd slot="head" data={breadcrumbLd} />

  <article class="detail">
    {/* BreadcrumbList DOM (D-03); matching BreadcrumbList JSON-LD emitted above (SEO-05). */}
    <nav aria-label="Breadcrumb" class="crumbs">
      <ol>
        <li><a href="/">Acasă</a></li>
        <li class="crumbs__sep" aria-hidden="true">›</li>
        <li><a href="/lucrari">Lucrări</a></li>
        <li class="crumbs__sep" aria-hidden="true">›</li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <h1 class="detail__title">{title}</h1>
    <p class="detail__meta">{location} · {dateLabel}</p>

    <div class="prose">
      <Content />
    </div>

    {
      hasPairs ? (
        <section class="media media--pairs" aria-label="Comparație înainte și după">
          {resolvedPairs.map((p) => (
            <BeforeAfter before={p.before} after={p.after} />
          ))}
        </section>
      ) : (
        <ul class="gallery" aria-label="Galerie foto — lucrarea finalizată">
          {resolvedGallery.map((g, i) => (
            <li class="gallery__item">
              <Picture
                src={g.img}
                formats={['avif', 'webp']}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 50vw"
                loading={i === 0 ? 'eager' : 'lazy'}
                alt={galleryAlt(g.path, i)}
              />
            </li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>

<style>
  .detail {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  @media (min-width: 768px) {
    .detail {
      padding: var(--space-2xl) var(--space-lg);
    }
  }

  /* ─── Breadcrumb ─────────────────────────────────────────────────────────── */
  .crumbs ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    margin: 0 0 var(--space-md);
    padding: 0;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
  }

  .crumbs li {
    display: flex;
    align-items: center;
  }

  /* WR-02: separator is an explicit aria-hidden <li> (not a CSS ::before),
     so VoiceOver/NVDA never announce the decorative '›' glyph. */
  .crumbs__sep {
    margin: 0 var(--space-xs);
    color: var(--color-slate-500);
    font-weight: 400;
  }

  .crumbs a {
    display: inline-flex;
    align-items: center;
    min-height: 48px; /* ≥48px hit area (WCAG 2.5.5) */
    color: var(--color-slate-700);
    text-decoration: none;
  }

  .crumbs a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .crumbs [aria-current='page'] {
    color: var(--color-slate-500);
  }

  /* ─── Header ─────────────────────────────────────────────────────────────── */
  .detail__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.75rem;
    line-height: 1.2;
    color: var(--color-slate-900);
    margin: 0 0 var(--space-xs);
  }

  @media (min-width: 768px) {
    .detail__title {
      font-size: 2rem;
    }
  }

  .detail__meta {
    margin: 0 0 var(--space-xl);
    color: var(--color-slate-700);
    font-size: 1rem;
  }

  /* ─── MDX prose ──────────────────────────────────────────────────────────── */
  .prose {
    max-width: 70ch;
    color: var(--color-slate-700);
    margin-bottom: var(--space-xl);
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-md);
    line-height: 1.5;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-lg);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(strong) {
    color: var(--color-slate-900);
  }

  @media (min-width: 768px) {
    .detail__meta,
    .prose {
      margin-bottom: var(--space-2xl);
    }
  }

  /* ─── Media region (full content-width) ──────────────────────────────────── */
  .media--pairs {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* ─── Gallery (after-only, mixed-orientation — Pitfall 6) ────────────────── */
  .gallery {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
    /* Tolerate uneven row heights so mixed portrait/landscape never crop badly. */
    align-items: start;
  }

  @media (min-width: 768px) {
    .gallery {
      gap: var(--space-lg);
    }
  }

  .gallery__item {
    border: 1px solid var(--color-slate-600);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
  }

  /* Each image keeps its OWN intrinsic aspect-ratio (no forced box → no crop). */
  .gallery__item :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
